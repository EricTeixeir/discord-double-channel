# São necessários DOIS bots: o Discord não deixa um mesmo bot ficar em dois
# canais de voz do mesmo servidor ao mesmo tempo.
# Bot A: entra no canal do Time A e é dono do comando /trashtalk.
# Bot B: só entra no canal do Time B.
DISCORD_TOKEN_A=token_do_bot_a
DISCORD_TOKEN_B=token_do_bot_b
# Senha do controle por hotkey/túnel. Gere algo aleatório e longo, ex.:
#   openssl rand -hex 24
CONTROL_TOKEN=gere_um_token_aleatorio_longo
# Onde a porta de controle escuta. Local (padrão): 127.0.0.1. Na VPS: 0.0.0.0
# para aceitar o F8 de fora (a proteção é o CONTROL_TOKEN).
#CONTROL_BIND=0.0.0.0
# Opcional. Desliga o relay sozinho após N segundos ligado (padrão: 20).
# Use 0 para deixar ligado até alguém desligar manualmente.
#RELAY_AUTO_OFF_SECONDS=20
GUILD_ID=id_do_servidor
CHANNEL_A_ID=id_canal_time_a
CHANNEL_B_ID=id_canal_time_b
